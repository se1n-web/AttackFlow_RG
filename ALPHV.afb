            "properties": [
                [
                    "name",
                    "Domain Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078.002"
                        ]
                    ]
                ],
                [
                    "description",
                    "ALPHV operators specifically target domain administrator and service account credentials, obtained through credential dumping, LDAP enumeration, or Kerberoasting. Domain account access enables unrestricted lateral movement across the Active Directory environment, GPO-based payload distribution, and the ability to disable security controls organisation-wide prior to encryption."
                ],
                [
                    "confidence",
                    null
                ],
