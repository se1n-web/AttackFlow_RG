                        ],
                        [
                            "technique",
                            "T1078.003"
                        ]
                    ]
                ],
                [
                    "description",
                    "ALPHV affiliates exploit reused or default local administrator credentials — particularly on servers and workstations lacking centralised credential management — to gain initial footholds or pivot between systems. Local account abuse is frequently chained with pass-the-hash techniques to move laterally without triggering domain-level authentication alerts."
                ],
                [
                    "confidence",
                    null
