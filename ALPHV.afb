                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1190"
                        ]
                    ]
                ],
                [
                    "description",
                    "ALPHV/BlackCat affiliates exploit known vulnerabilities in externally accessible services — including Exchange (ProxyShell/ProxyLogon), Fortinet VPNs (CVE-2018-13379), Citrix ADC, and VMware ESXi — to achieve unauthenticated initial access. Exploitation of perimeter devices provides a direct internal foothold, bypassing authentication entirely and enabling rapid lateral movement before defenders can respond."
                ],
