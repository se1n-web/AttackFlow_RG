                        ]
                    ]
                ],
                [
                    "description",
                    "ALPHV affiliates deliver highly targeted phishing emails carrying malicious attachments — including macro-laced Office documents, LNK files, and ISO containers — that execute loaders or droppers upon opening. The initial payload establishes a beachhead for deploying Cobalt Strike or Brute Ratel C4 beacons and conducting post-exploitation activities."
                ],
