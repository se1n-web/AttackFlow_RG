        {
            "id": "action",
            "instance": "dec06b76-fdc9-4402-8d69-f755ab155726",
            "properties": [
                [
                    "name",
                    "Phishing"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566"
                        ]
                    ]
                ],
                [
                    "description",
                    "Cl0p affiliates initiate intrusions through broad and targeted phishing campaigns, delivering deceptive emails that carry malicious attachments or embedded links to victims across targeted sectors including finance, healthcare, and critical infrastructure. Phishing serves as Cl0p's primary human-layer exploitation vector (Reports count: 3), enabling initial credential theft or loader execution that precedes Cl0p ransomware staging. Campaigns are tailored to impersonate trusted entities such as regulatory bodies, logistics providers, or internal IT helpdesks, increasing the likelihood of victim interaction."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
