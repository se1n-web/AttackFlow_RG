        {
            "id": "action",
            "instance": "2ea121f3-c1f5-4173-8f41-f16284ba3809",
            "properties": [
                [
                    "name",
                    "Valid Accounts"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078"
                        ]
                    ]
                ],
                [
                    "description",
                    "Cl0p affiliates acquire and abuse valid credentials — including domain accounts (T1078.002) and local accounts (T1078.003) — to authenticate to victim environments and maintain persistent access with reduced detection risk (Reports count: 2). Credentials are obtained through prior phishing campaigns that harvested them via fake login portals, purchased from initial access brokers, or extracted via credential dumping during active intrusions. Valid credentials allow the group to authenticate directly to VPN gateways, RDP endpoints, and enterprise management platforms while blending with normal administrator activity."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
