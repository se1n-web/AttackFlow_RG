        {
            "id": "action",
            "instance": "9d3a972e-121e-4ede-b247-bc64c3e3e451",
            "properties": [
                [
                    "name",
                    "Spearphishing Link"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566.002"
                        ]
                    ]
                ],
                [
                    "description",
                    "Phishing emails attributed to Cl0p operations embed URLs pointing to attacker-controlled or compromised infrastructure (Reports count: 2). Clicking the link directs victims to credential-harvesting portals mimicking corporate SSO or VPN login pages, or to sites delivering drive-by malware. This sub-technique complements attachment-based delivery by evading email gateway controls that block executable attachments, while still enabling credential capture or payload staging needed to authenticate to remote services and progress the intrusion."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
