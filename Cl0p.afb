        {
            "id": "action",
            "instance": "dce96eaf-3ec8-4d56-851d-7a1e2c289ea9",
            "properties": [
                [
                    "name",
                    "Exploit Public-Facing Application"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1190"
                        ]
                    ]
                ],
                [
                    "description",
                    "Cl0p is best known for large-scale exploitation of vulnerabilities in internet-facing managed file transfer and enterprise platforms, making T1190 the group's most reported initial access technique (Reports count: 7). Campaigns have exploited critical CVEs in Accellion FTA (CVE-2021-27101/27104), SolarWinds Serv-U (CVE-2021-35211), GoAnywhere MFT (CVE-2023-0669), and MOVEit Transfer (CVE-2023-34362/35036/35708). Successful exploitation provides unauthenticated remote code execution or arbitrary file read on externally exposed systems, enabling immediate data exfiltration or pivot into internal networks without requiring user interaction or valid credentials."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
