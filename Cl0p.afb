        {
            "id": "action",
            "instance": "531dd1d6-8407-42ca-8583-de6ef688406e",
            "properties": [
                [
                    "name",
                    "Spearphishing Attachment"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566.001"
                        ]
                    ]
                ],
                [
                    "description",
                    "Cl0p delivers malicious email attachments — commonly macro-enabled Office documents (Excel .xlsm, Word .docm), ISO archives, or shortcut (.lnk) files — that execute a loader or dropper upon opening (Reports count: 3). Loaders associated with Cl0p campaigns include FlawedAmmyy, Cobalt Strike beacons, and SDBot, which establish C2 connectivity and enable follow-on credential access and lateral movement. User execution is often triggered via social engineering content that instructs victims to enable macros or open nested archives, bypassing automated attachment scanning."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
