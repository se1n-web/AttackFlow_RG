{"schema": "attack_flow_v2", "theme": "dark_theme", "objects": [{"id": "flow", "instance": "6af6e30a-f00b-41d9-bc62-7f95a829db4a", "properties": [["name", "Cl0p"], ["description", null], ["author", [["name", "BBS CTI"], ["identity_class", "organization"], ["contact_information", null]]], ["scope", "incident"], ["classification", [["marking", null], ["group", null]]], ["external_references", [["ba01a6a19c8e400780f8f99b493eb30c", [["source_name", "Group IB"], ["description", "Group-IB Threat Intelligence :: Matrix"], ["url", null]]]]], ["created", {"time": "2026-06-18T17:00:00.000+08:00", "zone": "Asia/Manila"}]], "objects": ["37bf7c4f-f8cb-4139-908d-8ad21b87b84b", "57f82209-d67d-4494-9bfc-2660639f21ba", "bb16da4c-28f7-423a-9a4c-0bf8e0811f45", "445013ba-f1d7-4e83-8eb5-1b82c457a7ed", "b933a007-4787-4008-8957-33a49e8afb02", "3b056678-aa68-4b68-88e6-5703bc9a9106", "5b19a863-7e4b-4f32-9596-73996dc359cd", "a77e3037-135a-4c11-bc81-59fe0a617e1b", "31336b9f-96a9-42cf-b81c-0d44d52ae5e5", "44fe498d-d41b-48bc-981d-6b963646a831", "dec06b76-fdc9-4402-8d69-f755ab155726", "531dd1d6-8407-42ca-8583-de6ef688406e", "9d3a972e-121e-4ede-b247-bc64c3e3e451", "2ea121f3-c1f5-4173-8f41-f16284ba3809", "dce96eaf-3ec8-4d56-851d-7a1e2c289ea9", "f7f3aaf6-44e3-4558-b618-d547db312ff1", "7d5c5dfe-f1e8-47fe-b30d-b185f2069854", "76d0b12e-367f-4a7d-9281-c72985cfcf2c", "b041e8e2-d8da-43d9-be09-22f43a951df7", "4aa90775-2f0c-4f95-95fe-a4ffa55da9d8"]}, {"id": "action", "instance": "dec06b76-fdc9-4402-8d69-f755ab155726", "properties": [["name", "Phishing"], ["ttp", [["tactic", "TA0001"], ["technique", "T1566"]]], ["description", "Cl0p affiliates initiate intrusions through broad and targeted phishing campaigns, delivering deceptive emails that carry malicious attachments or embedded links to victims across targeted sectors including finance, healthcare, and critical infrastructure. Phishing serves as Cl0p's primary human-layer exploitation vector (Reports count: 3), enabling initial credential theft or loader execution that precedes Cl0p ransomware staging. Campaigns are tailored to impersonate trusted entities such as regulatory bodies, logistics providers, or internal IT helpdesks, increasing the likelihood of victim interaction."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "23374982-3d72-4465-a8d7-f4c3633217a3", "30": "5519130b-3f22-46b5-9903-49fb6d6fc427", "60": "fb747042-ba6e-42cd-992f-c89f91412645", "90": "f7b9583d-ffd7-4cdb-a85b-bb60b60e1988", "120": "92108df2-53c1-4040-9247-19ab4e0f5d92", "150": "4aeb6f9b-49cd-4d85-84af-8336c925a445", "180": "db9aeb85-dd93-4ab1-8e6b-c550ac600319", "210": "f5e10c54-d059-47fd-99b2-913f6bf919b2", "240": "41281ddc-fd0c-457c-8753-089db5906eb6", "270": "b54c62d4-a086-47b9-bd56-fd8711ff608e", "300": "48dd2f10-12c7-4e6d-82ff-06a33ae5e497", "330": "f450b91b-657c-42a5-8d47-4d9db1b97312"}}, {"id": "horizontal_anchor", "instance": "23374982-3d72-4465-a8d7-f4c3633217a3", "latches": []}, {"id": "vertical_anchor", "instance": "5519130b-3f22-46b5-9903-49fb6d6fc427", "latches": []}, {"id": "vertical_anchor", "instance": "fb747042-ba6e-42cd-992f-c89f91412645", "latches": []}, {"id": "vertical_anchor", "instance": "f7b9583d-ffd7-4cdb-a85b-bb60b60e1988", "latches": ["f804c23d-5c19-4ffd-ad44-4c23bc2a1102"]}, {"id": "vertical_anchor", "instance": "92108df2-53c1-4040-9247-19ab4e0f5d92", "latches": ["c443272d-b073-4edb-82e4-c0e084b20c5b"]}, {"id": "vertical_anchor", "instance": "4aeb6f9b-49cd-4d85-84af-8336c925a445", "latches": []}, {"id": "horizontal_anchor", "instance": "db9aeb85-dd93-4ab1-8e6b-c550ac600319", "latches": []}, {"id": "vertical_anchor", "instance": "f5e10c54-d059-47fd-99b2-913f6bf919b2", "latches": []}, {"id": "vertical_anchor", "instance": "41281ddc-fd0c-457c-8753-089db5906eb6", "latches": []}, {"id": "vertical_anchor", "instance": "b54c62d4-a086-47b9-bd56-fd8711ff608e", "latches": []}, {"id": "vertical_anchor", "instance": "48dd2f10-12c7-4e6d-82ff-06a33ae5e497", "latches": []}, {"id": "vertical_anchor", "instance": "f450b91b-657c-42a5-8d47-4d9db1b97312", "latches": []}, {"id": "action", "instance": "531dd1d6-8407-42ca-8583-de6ef688406e", "properties": [["name", "Spearphishing Attachment"], ["ttp", [["tactic", "TA0001"], ["technique", "T1566.001"]]], ["description", "Cl0p delivers malicious email attachments \u2014 commonly macro-enabled Office documents (Excel .xlsm, Word .docm), ISO archives, or shortcut (.lnk) files \u2014 that execute a loader or dropper upon opening (Reports count: 3). Loaders associated with Cl0p campaigns include FlawedAmmyy, Cobalt Strike beacons, and SDBot, which establish C2 connectivity and enable follow-on credential access and lateral movement. User execution is often triggered via social engineering content that instructs victims to enable macros or open nested archives, bypassing automated attachment scanning."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "2d7ec389-3a4b-4839-9fa6-8aa8870577fa", "30": "04d69f12-4845-4b28-b980-5c137185a586", "60": "fddb6781-37c7-4e22-b3af-c14fe8da195c", "90": "db2eff94-573f-43c3-939e-ecf03b75a367", "120": "afa26cc1-b7dd-4d61-a306-8083db653071", "150": "494bf4bb-d5f9-4fd5-afa7-dba4e5a42d20", "180": "7275818a-035e-4463-9c51-3b3f15ab2529", "210": "33774240-4306-4d7d-addd-231f13ad1a95", "240": "9ee2f861-4b64-4cb2-8e67-fbc84e76c3b5", "270": "d5b1ed67-0984-496a-be08-214bedf88915", "300": "f85ac14b-198d-4624-8105-c8eb06101e2d", "330": "a54af95b-ded1-4c78-a507-7e6c11553dc9"}}, {"id": "horizontal_anchor", "instance": "2d7ec389-3a4b-4839-9fa6-8aa8870577fa", "latches": []}, {"id": "vertical_anchor", "instance": "04d69f12-4845-4b28-b980-5c137185a586", "latches": []}, {"id": "vertical_anchor", "instance": "fddb6781-37c7-4e22-b3af-c14fe8da195c", "latches": []}, {"id": "vertical_anchor", "instance": "db2eff94-573f-43c3-939e-ecf03b75a367", "latches": ["68563608-a60c-408e-aafa-59da484dbed8"]}, {"id": "vertical_anchor", "instance": "afa26cc1-b7dd-4d61-a306-8083db653071", "latches": []}, {"id": "vertical_anchor", "instance": "494bf4bb-d5f9-4fd5-afa7-dba4e5a42d20", "latches": []}, {"id": "horizontal_anchor", "instance": "7275818a-035e-4463-9c51-3b3f15ab2529", "latches": []}, {"id": "vertical_anchor", "instance": "33774240-4306-4d7d-addd-231f13ad1a95", "latches": []}, {"id": "vertical_anchor", "instance": "9ee2f861-4b64-4cb2-8e67-fbc84e76c3b5", "latches": []}, {"id": "vertical_anchor", "instance": "d5b1ed67-0984-496a-be08-214bedf88915", "latches": ["8035d59f-c917-4f52-a4f4-5a700caed8d4"]}, {"id": "vertical_anchor", "instance": "f85ac14b-198d-4624-8105-c8eb06101e2d", "latches": []}, {"id": "vertical_anchor", "instance": "a54af95b-ded1-4c78-a507-7e6c11553dc9", "latches": []}, {"id": "action", "instance": "9d3a972e-121e-4ede-b247-bc64c3e3e451", "properties": [["name", "Spearphishing Link"], ["ttp", [["tactic", "TA0001"], ["technique", "T1566.002"]]], ["description", "Phishing emails attributed to Cl0p operations embed URLs pointing to attacker-controlled or compromised infrastructure (Reports count: 2). Clicking the link directs victims to credential-harvesting portals mimicking corporate SSO or VPN login pages, or to sites delivering drive-by malware. This sub-technique complements attachment-based delivery by evading email gateway controls that block executable attachments, while still enabling credential capture or payload staging needed to authenticate to remote services and progress the intrusion."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "6c1cf756-8bbf-4d6e-8847-0cd6afaf6b4c", "30": "8f9cc132-6070-440e-90c8-dc039434a1f7", "60": "0eb9760e-d713-491e-8b2c-dc04cfddfad6", "90": "6980ded3-5366-40ae-ab38-a7de543b748a", "120": "2eb22563-dba9-44de-bb1f-52646e3c6c58", "150": "5e87aa48-a908-4e8a-96cb-10c1223d5df6", "180": "1cfd76a8-5e19-4a3c-8510-8597203ed1c3", "210": "78d966f7-df95-417f-a4fa-633128cc19a7", "240": "c1e08024-14c2-4758-bef9-f941d6f1795c", "270": "84f1ea2d-eb6e-4d3e-b36f-c55010e3bdf3", "300": "e2457b77-e6a3-4f7a-b3a3-47f5570b1f9d", "330": "778f0ab1-1031-41eb-8fbc-585c1f5e671f"}}, {"id": "horizontal_anchor", "instance": "6c1cf756-8bbf-4d6e-8847-0cd6afaf6b4c", "latches": []}, {"id": "vertical_anchor", "instance": "8f9cc132-6070-440e-90c8-dc039434a1f7", "latches": []}, {"id": "vertical_anchor", "instance": "0eb9760e-d713-491e-8b2c-dc04cfddfad6", "latches": []}, {"id": "vertical_anchor", "instance": "6980ded3-5366-40ae-ab38-a7de543b748a", "latches": ["4075193a-b393-4112-bacb-fb46ce3f96a2"]}, {"id": "vertical_anchor", "instance": "2eb22563-dba9-44de-bb1f-52646e3c6c58", "latches": []}, {"id": "vertical_anchor", "instance": "5e87aa48-a908-4e8a-96cb-10c1223d5df6", "latches": []}, {"id": "horizontal_anchor", "instance": "1cfd76a8-5e19-4a3c-8510-8597203ed1c3", "latches": []}, {"id": "vertical_anchor", "instance": "78d966f7-df95-417f-a4fa-633128cc19a7", "latches": []}, {"id": "vertical_anchor", "instance": "c1e08024-14c2-4758-bef9-f941d6f1795c", "latches": []}, {"id": "vertical_anchor", "instance": "84f1ea2d-eb6e-4d3e-b36f-c55010e3bdf3", "latches": ["8c581ac4-4f90-4771-aaee-be597b32c964"]}, {"id": "vertical_anchor", "instance": "e2457b77-e6a3-4f7a-b3a3-47f5570b1f9d", "latches": []}, {"id": "vertical_anchor", "instance": "778f0ab1-1031-41eb-8fbc-585c1f5e671f", "latches": []}, {"id": "action", "instance": "2ea121f3-c1f5-4173-8f41-f16284ba3809", "properties": [["name", "Valid Accounts"], ["ttp", [["tactic", "TA0001"], ["technique", "T1078"]]], ["description", "Cl0p affiliates acquire and abuse valid credentials \u2014 including domain accounts (T1078.002) and local accounts (T1078.003) \u2014 to authenticate to victim environments and maintain persistent access with reduced detection risk (Reports count: 2). Credentials are obtained through prior phishing campaigns that harvested them via fake login portals, purchased from initial access brokers, or extracted via credential dumping during active intrusions. Valid credentials allow the group to authenticate directly to VPN gateways, RDP endpoints, and enterprise management platforms while blending with normal administrator activity."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "1016d195-9f9f-4d7b-b8e4-c24c50babb93", "30": "1e1fad75-9f6f-45ac-acf2-ff765aa5d1c4", "60": "85578503-a9ab-4780-8f77-1cf5d5eae283", "90": "fac8ac24-463f-41ba-8d1e-c1a7b02cc4ae", "120": "7797a3b0-55fe-4559-9e7d-7d53a584edfc", "150": "b20a8f54-6afe-4749-84cb-8e9930acddba", "180": "5101c8aa-37f2-4df9-ac6b-309249dac88b", "210": "7b19cc99-2031-44e8-a74c-b1e7c115647a", "240": "38033856-f773-457b-905f-4bc21cfc93b4", "270": "22c75290-dc63-46ee-830c-7badf4b5bcbb", "300": "4e11c9ac-596d-42fd-b4fe-6dd328957291", "330": "12a93841-2664-42d8-a5e0-3bb0996a446f"}}, {"id": "horizontal_anchor", "instance": "1016d195-9f9f-4d7b-b8e4-c24c50babb93", "latches": []}, {"id": "vertical_anchor", "instance": "1e1fad75-9f6f-45ac-acf2-ff765aa5d1c4", "latches": []}, {"id": "vertical_anchor", "instance": "85578503-a9ab-4780-8f77-1cf5d5eae283", "latches": []}, {"id": "vertical_anchor", "instance": "fac8ac24-463f-41ba-8d1e-c1a7b02cc4ae", "latches": ["49d393b2-4dae-4e3f-b6ea-95ea3533a233"]}, {"id": "vertical_anchor", "instance": "7797a3b0-55fe-4559-9e7d-7d53a584edfc", "latches": []}, {"id": "vertical_anchor", "instance": "b20a8f54-6afe-4749-84cb-8e9930acddba", "latches": []}, {"id": "horizontal_anchor", "instance": "5101c8aa-37f2-4df9-ac6b-309249dac88b", "latches": []}, {"id": "vertical_anchor", "instance": "7b19cc99-2031-44e8-a74c-b1e7c115647a", "latches": []}, {"id": "vertical_anchor", "instance": "38033856-f773-457b-905f-4bc21cfc93b4", "latches": []}, {"id": "vertical_anchor", "instance": "22c75290-dc63-46ee-830c-7badf4b5bcbb", "latches": []}, {"id": "vertical_anchor", "instance": "4e11c9ac-596d-42fd-b4fe-6dd328957291", "latches": []}, {"id": "vertical_anchor", "instance": "12a93841-2664-42d8-a5e0-3bb0996a446f", "latches": []}, {"id": "action", "instance": "dce96eaf-3ec8-4d56-851d-7a1e2c289ea9", "properties": [["name", "Exploit Public-Facing Application"], ["ttp", [["tactic", "TA0001"], ["technique", "T1190"]]], ["description", "Cl0p is best known for large-scale exploitation of vulnerabilities in internet-facing managed file transfer and enterprise platforms, making T1190 the group's most reported initial access technique (Reports count: 7). Campaigns have exploited critical CVEs in Accellion FTA (CVE-2021-27101/27104), SolarWinds Serv-U (CVE-2021-35211), GoAnywhere MFT (CVE-2023-0669), and MOVEit Transfer (CVE-2023-34362/35036/35708). Successful exploitation provides unauthenticated remote code execution or arbitrary file read on externally exposed systems, enabling immediate data exfiltration or pivot into internal networks without requiring user interaction or valid credentials."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "8886758f-657c-4f41-a67d-2d1fabe3336a", "30": "57ac5620-9cd8-4453-b9aa-d3cd23ef3c4e", "60": "b2b0849b-4d6f-4faa-a58c-93ee3d18fbfb", "90": "51c58fb9-e07a-4267-ade0-276a6af4dc87", "120": "771d4d29-a866-4ffa-930a-9db0e3042760", "150": "a340ebce-d6b1-4f39-97e6-6526ea5b83e1", "180": "5ac5a819-0816-4f5d-b1da-8162f803687b", "210": "841d0ef6-d85f-46d7-886f-25a77347cc3e", "240": "9bc46a5c-b6f9-4583-94a9-ad8847f4180f", "270": "18aa9b20-abd5-4e14-9941-2b488e8ee6e9", "300": "4133c744-54bb-47c0-9d77-e54d89195102", "330": "f24b6d34-666e-42f2-be99-3d4d29f31f5e"}}, {"id": "horizontal_anchor", "instance": "8886758f-657c-4f41-a67d-2d1fabe3336a", "latches": []}, {"id": "vertical_anchor", "instance": "57ac5620-9cd8-4453-b9aa-d3cd23ef3c4e", "latches": []}, {"id": "vertical_anchor", "instance": "b2b0849b-4d6f-4faa-a58c-93ee3d18fbfb", "latches": []}, {"id": "vertical_anchor", "instance": "51c58fb9-e07a-4267-ade0-276a6af4dc87", "latches": ["6b909df6-83a3-426c-8cb0-b1559b308361"]}, {"id": "vertical_anchor", "instance": "771d4d29-a866-4ffa-930a-9db0e3042760", "latches": []}, {"id": "vertical_anchor", "instance": "a340ebce-d6b1-4f39-97e6-6526ea5b83e1", "latches": []}, {"id": "horizontal_anchor", "instance": "5ac5a819-0816-4f5d-b1da-8162f803687b", "latches": []}, {"id": "vertical_anchor", "instance": "841d0ef6-d85f-46d7-886f-25a77347cc3e", "latches": []}, {"id": "vertical_anchor", "instance": "9bc46a5c-b6f9-4583-94a9-ad8847f4180f", "latches": []}, {"id": "vertical_anchor", "instance": "18aa9b20-abd5-4e14-9941-2b488e8ee6e9", "latches": []}, {"id": "vertical_anchor", "instance": "4133c744-54bb-47c0-9d77-e54d89195102", "latches": []}, {"id": "vertical_anchor", "instance": "f24b6d34-666e-42f2-be99-3d4d29f31f5e", "latches": []}, {"id": "action", "instance": "f7f3aaf6-44e3-4558-b618-d547db312ff1", "properties": [["name", "External Remote Services"], ["ttp", [["tactic", "TA0001"], ["technique", "T1133"]]], ["description", "Following initial access via phishing, credential theft, or exploitation, Cl0p affiliates authenticate to internet-exposed remote access services \u2014 including VPN gateways, RDP endpoints, and remote management platforms \u2014 to establish a persistent, authenticated tunnel into the internal network. Valid stolen credentials enable direct access to these services, bypassing perimeter controls and providing a stable foothold from which to conduct hands-on-keyboard operations. External remote services are used in conjunction with all other initial access vectors, serving as the pivot point into internal network segments including the login node, management infrastructure, enterprise systems, and HPC compute environments."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "e013e830-e78b-405f-a163-2123eebb3c83", "30": "23464e00-d505-42b6-a473-002857043871", "60": "a6f25f03-c253-450d-a3c7-a17849ef21ff", "90": "d354ae0e-9ddf-43f0-acca-e78577f44846", "120": "7dde8c45-afc5-4edc-838a-5405c4c9ae81", "150": "ab0a2d39-3642-40e1-b3cf-cf177f311b76", "180": "61e19741-2329-4f61-92d1-99dd6b0