                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1078"
                        ]
                    ]
                ],
                [
                    "description",
                    "Hive affiliates obtain valid credentials through phishing, credential-theft malware, or purchase on underground markets, then use them to authenticate to internet-facing services. Leveraging legitimate accounts blends attacker activity with normal user behaviour, evading anomaly-based detections and enabling persistent access."
                ],
                [
                    "confidence",
                    null
                ],
