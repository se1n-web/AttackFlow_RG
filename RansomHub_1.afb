        {
            "id": "action",
            "instance": "e9c2a2fc-dabd-48e1-8e10-a0845fdbb00f",
            "properties": [
                [
                    "name",
                    "Spearphishing Link"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566.002"
                        ]
                    ]
                ],
                [
                    "description",
                    "RansomHub phishing emails embed URLs directing victims to attacker-controlled infrastructure hosting credential-harvesting portals or drive-by malware delivery pages. Link-based phishing is used to capture valid domain credentials — particularly for VPN, Microsoft 365, and corporate SSO portals — which are then reused to authenticate to external remote services in subsequent intrusion phases. This sub-technique complements attachment delivery by targeting environments with strong attachment-filtering controls, and is frequently paired with adversary-in-the-middle frameworks or reverse proxies that relay authentication tokens in real time, bypassing multi-factor authentication protections on targeted accounts."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
