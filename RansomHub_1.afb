        {
            "id": "action",
            "instance": "90f5a7f5-5429-4bca-abba-a6576c078a26",
            "properties": [
                [
                    "name",
                    "External Remote Services"
                ],
                [
                    "ttp",
                    [
                        [
                            "tactic",
                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1133"
                        ]
                    ]
                ],
                [
                    "description",
                    "External Remote Services is the central convergence point for all RansomHub initial access vectors, observed in both initial access and persistence tactics (Reports count: 2 each). Following credential theft via phishing or brute force, exploitation of public-facing applications, or drive-by compromise, RansomHub affiliates authenticate to internet-exposed remote access services — including VPN gateways (Citrix, Fortinet, Pulse Secure), RDP endpoints, and remote management platforms (AnyDesk, ConnectWise) — to establish a persistent, authenticated tunnel into the internal network. These services serve as the primary pivot point into internal network segments, enabling hands-on-keyboard operations including privilege escalation (T1484.001, T1068), security tool disabling (T1562.001, Reports count: 4), and lateral movement via RDP (T1021.001, Reports count: 3) and SMB (T1021.002) ahead of ransomware detonation and system service termination (T1489)."
                ],
                [
                    "confidence",
                    null
                ],
                [
                    "execution_start",
                    null
                ],
                [
                    "execution_end",
                    null
                ]
            ],
