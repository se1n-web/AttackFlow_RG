{"schema": "attack_flow_v2", "theme": "dark_theme", "objects": [{"id": "flow", "instance": "65537f47-d884-4f72-a32c-0cebd634efbb", "properties": [["name", "RansomHub"], ["description", null], ["author", [["name", "BBS CTI"], ["identity_class", "organization"], ["contact_information", null]]], ["scope", "incident"], ["classification", [["marking", null], ["group", null]]], ["external_references", [["eaa4cbc14e5b42a99a0a936511321966", [["source_name", "Group IB"], ["description", "Group-IB Threat Intelligence :: Matrix"], ["url", null]]]]], ["created", {"time": "2026-06-18T17:00:00.000+08:00", "zone": "Asia/Manila"}]], "objects": ["c6ca243e-5655-4187-8ff4-2bc67b462418", "88c52a61-ad82-4b1f-83ee-03b878e4c6eb", "f11933e5-3bd9-4d70-8521-b47846ea78c6", "e35ef7a8-017c-4ac2-af8b-3fe42bd6e384", "7394d3c0-ce0f-4b5e-afbf-48bf4816864b", "a9cbf9a3-f2b6-40d9-8f72-d215b2cba1df", "f31ab5f6-3aec-420c-8433-b4db640672c0", "dd2a9110-1c14-47a5-97f4-74a76ce1e6f0", "03c6bb9e-8c96-48cf-90d3-61ba03b5cc83", "e2c6c41a-deda-4417-8f99-10fb9544784b", "0fdee220-c411-437b-9e8a-37755a51b185", "b7aa632a-9512-4ba8-898b-c50bbd1fe81b", "fffdea43-9c41-422c-90a9-a9c9c6fa0b6e", "e9c2a2fc-dabd-48e1-8e10-a0845fdbb00f", "d31656d6-0f83-4319-91c5-ecdde4c0f5f2", "28a55f7c-cfd6-47d0-b32f-a52ed698aba3", "fcca1598-bb70-4a88-ae1f-b08a27a92362", "90f5a7f5-5429-4bca-abba-a6576c078a26", "54a755a5-af13-4b94-8ba7-b38e32bc832a", "fea104f2-6a20-4f5f-9657-e4e6a9101db3", "af11b0b4-d091-48f1-b8c6-6b804752b730", "edbff35a-87c7-40b6-8b2f-dbaa86e5fb63"]}, {"id": "action", "instance": "b7aa632a-9512-4ba8-898b-c50bbd1fe81b", "properties": [["name", "Phishing"], ["ttp", [["tactic", "TA0001"], ["technique", "T1566"]]], ["description", "RansomHub affiliates use phishing as an initial access vector, delivering deceptive emails that impersonate trusted entities \u2014 including business partners, financial institutions, and IT service providers \u2014 to lure victims into interacting with malicious content. Phishing enables both credential harvesting and direct malware delivery, providing the foothold needed to authenticate to external remote services or execute tooling on victim hosts. The technique branches into two delivery sub-techniques: malicious attachments (T1566.001) that execute loaders or droppers upon opening, and malicious links (T1566.002) that redirect victims to credential-harvesting portals or payload-staging infrastructure. Phishing complements RansomHub's other initial access vectors and is used selectively against targets where exposed services or exploitable vulnerabilities are not available."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "bd02e59b-41bc-4b5c-8164-88bb04e5b3bc", "30": "e4fe3980-e9f8-4629-97c5-6bc0b1073f24", "60": "f64fce28-31f8-4445-ad38-89e6afa26ddb", "90": "ed9698f0-1a2b-4218-924c-2c852e1a7d72", "120": "26247322-efc1-4384-88a4-e7f885eadc29", "150": "d95147da-53d4-4bfc-aa1a-2aaf4e0aadcf", "180": "0340afbd-f149-4494-95b5-e22664f0f587", "210": "632f1800-f1a0-49b8-97df-cde9525829b5", "240": "bfd96df6-b100-4bff-b42a-5cc5a06b34b1", "270": "e7e2d31e-475b-47f6-9b66-016ad10c8094", "300": "b17c68bb-165d-4795-9f0f-e6fca4bbb58f", "330": "6ed48b5c-7980-499b-b18a-48080c5d61ed"}}, {"id": "horizontal_anchor", "instance": "bd02e59b-41bc-4b5c-8164-88bb04e5b3bc", "latches": []}, {"id": "vertical_anchor", "instance": "e4fe3980-e9f8-4629-97c5-6bc0b1073f24", "latches": []}, {"id": "vertical_anchor", "instance": "f64fce28-31f8-4445-ad38-89e6afa26ddb", "latches": []}, {"id": "vertical_anchor", "instance": "ed9698f0-1a2b-4218-924c-2c852e1a7d72", "latches": ["2ede4385-1556-42eb-9013-607128c047d6"]}, {"id": "vertical_anchor", "instance": "26247322-efc1-4384-88a4-e7f885eadc29", "latches": ["013774fb-0192-4f1e-9b46-d35b28e78a61"]}, {"id": "vertical_anchor", "instance": "d95147da-53d4-4bfc-aa1a-2aaf4e0aadcf", "latches": []}, {"id": "horizontal_anchor", "instance": "0340afbd-f149-4494-95b5-e22664f0f587", "latches": []}, {"id": "vertical_anchor", "instance": "632f1800-f1a0-49b8-97df-cde9525829b5", "latches": []}, {"id": "vertical_anchor", "instance": "bfd96df6-b100-4bff-b42a-5cc5a06b34b1", "latches": []}, {"id": "vertical_anchor", "instance": "e7e2d31e-475b-47f6-9b66-016ad10c8094", "latches": []}, {"id": "vertical_anchor", "instance": "b17c68bb-165d-4795-9f0f-e6fca4bbb58f", "latches": []}, {"id": "vertical_anchor", "instance": "6ed48b5c-7980-499b-b18a-48080c5d61ed", "latches": []}, {"id": "action", "instance": "fffdea43-9c41-422c-90a9-a9c9c6fa0b6e", "properties": [["name", "Spearphishing Attachment"], ["ttp", [["tactic", "TA0001"], ["technique", "T1566.001"]]], ["description", "RansomHub phishing emails deliver malicious file attachments \u2014 commonly macro-enabled Office documents, HTML smuggling payloads, or archive files containing executables \u2014 that drop or execute a loader when opened by the victim. Observed payloads in RansomHub campaigns include Cobalt Strike beacons, SystemBC, and commodity RATs that establish C2 connectivity and enable follow-on credential access. Attachment delivery bypasses link-filtering controls and provides direct code execution on the victim host, accelerating the timeline from initial access to lateral movement and ransomware staging. User execution (T1204.002) is relied upon to trigger the payload, often aided by social engineering content instructing the recipient to enable macros or extract and run the enclosed file."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "365ae944-78e7-4e35-a830-45962756c26f", "30": "2e9c0205-ed33-4168-8bc3-6a5d81ec8d83", "60": "011ea454-8597-48c3-9c45-d3b2656ebbc5", "90": "55d92493-95ac-4037-953f-706db0ae95ab", "120": "5031bc39-5591-49b2-907d-710aa617e4ac", "150": "11807094-e20b-4c77-ab8e-267e31ace28b", "180": "2a71bfbc-d1b9-439f-b740-e841512f4005", "210": "1c94005f-7649-42ed-8543-de11a8e616d5", "240": "74f80848-6c10-44ef-b58c-79981a8be2f4", "270": "45a0f6d4-39e0-4b28-a189-fc18ff9df6c1", "300": "db7d4e8d-4170-41f9-a563-aba08cbbf7b6", "330": "ec1fd804-3d77-4172-92fb-c85e479cde8b"}}, {"id": "horizontal_anchor", "instance": "365ae944-78e7-4e35-a830-45962756c26f", "latches": []}, {"id": "vertical_anchor", "instance": "2e9c0205-ed33-4168-8bc3-6a5d81ec8d83", "latches": []}, {"id": "vertical_anchor", "instance": "011ea454-8597-48c3-9c45-d3b2656ebbc5", "latches": []}, {"id": "vertical_anchor", "instance": "55d92493-95ac-4037-953f-706db0ae95ab", "latches": ["030d3685-77cb-4a43-a30c-99c106abad78"]}, {"id": "vertical_anchor", "instance": "5031bc39-5591-49b2-907d-710aa617e4ac", "latches": []}, {"id": "vertical_anchor", "instance": "11807094-e20b-4c77-ab8e-267e31ace28b", "latches": []}, {"id": "horizontal_anchor", "instance": "2a71bfbc-d1b9-439f-b740-e841512f4005", "latches": []}, {"id": "vertical_anchor", "instance": "1c94005f-7649-42ed-8543-de11a8e616d5", "latches": []}, {"id": "vertical_anchor", "instance": "74f80848-6c10-44ef-b58c-79981a8be2f4", "latches": []}, {"id": "vertical_anchor", "instance": "45a0f6d4-39e0-4b28-a189-fc18ff9df6c1", "latches": ["ed7b99da-6114-4d0f-81a0-0473452ade56"]}, {"id": "vertical_anchor", "instance": "db7d4e8d-4170-41f9-a563-aba08cbbf7b6", "latches": []}, {"id": "vertical_anchor", "instance": "ec1fd804-3d77-4172-92fb-c85e479cde8b", "latches": []}, {"id": "action", "instance": "e9c2a2fc-dabd-48e1-8e10-a0845fdbb00f", "properties": [["name", "Spearphishing Link"], ["ttp", [["tactic", "TA0001"], ["technique", "T1566.002"]]], ["description", "RansomHub phishing emails embed URLs directing victims to attacker-controlled infrastructure hosting credential-harvesting portals or drive-by malware delivery pages. Link-based phishing is used to capture valid domain credentials \u2014 particularly for VPN, Microsoft 365, and corporate SSO portals \u2014 which are then reused to authenticate to external remote services in subsequent intrusion phases. This sub-technique complements attachment delivery by targeting environments with strong attachment-filtering controls, and is frequently paired with adversary-in-the-middle frameworks or reverse proxies that relay authentication tokens in real time, bypassing multi-factor authentication protections on targeted accounts."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "ddc8efa0-80b7-40ea-8308-0a5ce70fa91a", "30": "d81403c9-9e36-4062-95ef-3ff4f05aa0c4", "60": "445a8781-76f1-4d97-9e1e-9a344738acec", "90": "554bad2b-89ee-4a4f-9ec9-b356b11979dd", "120": "5b575a61-be49-4137-99b6-16703a41aefb", "150": "44f22775-4fb2-4a3e-8261-be598bdcc9a9", "180": "c12676c4-abb9-41d8-bc0a-9d9f74aeda4d", "210": "8e3e6de5-5a4a-46a1-8f8b-c35792b5e7e5", "240": "91dd3462-0b5e-40b7-8d13-2e58593f9e77", "270": "94eb9a34-3b26-455e-bf1c-379aaab6ff05", "300": "f9811687-f712-4e9b-946a-7d350f24ed3c", "330": "6753cea2-3dcb-4d42-9761-038333e38234"}}, {"id": "horizontal_anchor", "instance": "ddc8efa0-80b7-40ea-8308-0a5ce70fa91a", "latches": []}, {"id": "vertical_anchor", "instance": "d81403c9-9e36-4062-95ef-3ff4f05aa0c4", "latches": []}, {"id": "vertical_anchor", "instance": "445a8781-76f1-4d97-9e1e-9a344738acec", "latches": []}, {"id": "vertical_anchor", "instance": "554bad2b-89ee-4a4f-9ec9-b356b11979dd", "latches": ["98c5b052-62ce-4e85-9b8f-60fa66b099d1"]}, {"id": "vertical_anchor", "instance": "5b575a61-be49-4137-99b6-16703a41aefb", "latches": []}, {"id": "vertical_anchor", "instance": "44f22775-4fb2-4a3e-8261-be598bdcc9a9", "latches": []}, {"id": "horizontal_anchor", "instance": "c12676c4-abb9-41d8-bc0a-9d9f74aeda4d", "latches": []}, {"id": "vertical_anchor", "instance": "8e3e6de5-5a4a-46a1-8f8b-c35792b5e7e5", "latches": []}, {"id": "vertical_anchor", "instance": "91dd3462-0b5e-40b7-8d13-2e58593f9e77", "latches": []}, {"id": "vertical_anchor", "instance": "94eb9a34-3b26-455e-bf1c-379aaab6ff05", "latches": ["010e4faf-042c-46bb-9fef-a78eea9788f2"]}, {"id": "vertical_anchor", "instance": "f9811687-f712-4e9b-946a-7d350f24ed3c", "latches": []}, {"id": "vertical_anchor", "instance": "6753cea2-3dcb-4d42-9761-038333e38234", "latches": []}, {"id": "action", "instance": "d31656d6-0f83-4319-91c5-ecdde4c0f5f2", "properties": [["name", "Valid Accounts"], ["ttp", [["tactic", "TA0001"], ["technique", "T1078"]]], ["description", "Valid credentials are the most consistently observed initial access vector in RansomHub intrusions, with domain accounts (T1078.002, Reports count: 3) being the primary sub-technique alongside local accounts (T1078.003). Credentials are sourced from initial access brokers operating in underground markets, prior phishing campaigns that harvested corporate SSO or VPN credentials, or credential stuffing attacks against exposed authentication endpoints. Once obtained, valid credentials allow RansomHub affiliates to authenticate directly to VPN gateways, RDP endpoints, and cloud management consoles without triggering exploit-based detection, providing a stealthy authenticated foothold that mirrors legitimate administrator behavior. Valid accounts are also reused across persistence (T1078.002 x3), privilege escalation, and defense evasion phases throughout the intrusion lifecycle."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "82662633-243a-4998-a1aa-da060f097e13", "30": "0c080dca-b151-4b02-a12e-2c82962a2389", "60": "88295293-f876-447a-8170-c8536b6d0b11", "90": "aef2d138-55c2-40cd-816f-c2d65b0feda8", "120": "8c42d7a8-9d86-44b4-a9fb-348476329665", "150": "6302f844-bac8-44a8-9f0d-ef03b99c7b3d", "180": "3bd8a6d4-1576-4f1b-92bf-c6b8d1cdab72", "210": "13edd646-0619-4ecf-9359-9a6b1957a920", "240": "418af7e2-4a33-43db-9b49-e8ea305888ef", "270": "c5fe7cf7-82c9-428e-aa8f-4c23af606129", "300": "f968371d-57e0-41be-9de0-13fa66096dcd", "330": "9f2e59da-1bf7-45f1-b8a1-9eeb618d453b"}}, {"id": "horizontal_anchor", "instance": "82662633-243a-4998-a1aa-da060f097e13", "latches": []}, {"id": "vertical_anchor", "instance": "0c080dca-b151-4b02-a12e-2c82962a2389", "latches": []}, {"id": "vertical_anchor", "instance": "88295293-f876-447a-8170-c8536b6d0b11", "latches": []}, {"id": "vertical_anchor", "instance": "aef2d138-55c2-40cd-816f-c2d65b0feda8", "latches": ["d92dfa02-6e2f-4de4-85f9-9c6ab826856c"]}, {"id": "vertical_anchor", "instance": "8c42d7a8-9d86-44b4-a9fb-348476329665", "latches": []}, {"id": "vertical_anchor", "instance": "6302f844-bac8-44a8-9f0d-ef03b99c7b3d", "latches": []}, {"id": "horizontal_anchor", "instance": "3bd8a6d4-1576-4f1b-92bf-c6b8d1cdab72", "latches": []}, {"id": "vertical_anchor", "instance": "13edd646-0619-4ecf-9359-9a6b1957a920", "latches": []}, {"id": "vertical_anchor", "instance": "418af7e2-4a33-43db-9b49-e8ea305888ef", "latches": []}, {"id": "vertical_anchor", "instance": "c5fe7cf7-82c9-428e-aa8f-4c23af606129", "latches": []}, {"id": "vertical_anchor", "instance": "f968371d-57e0-41be-9de0-13fa66096dcd", "latches": []}, {"id": "vertical_anchor", "instance": "9f2e59da-1bf7-45f1-b8a1-9eeb618d453b", "latches": []}, {"id": "action", "instance": "28a55f7c-cfd6-47d0-b32f-a52ed698aba3", "properties": [["name", "Exploit Public-Facing Application"], ["ttp", [["tactic", "TA0001"], ["technique", "T1190"]]], ["description", "RansomHub affiliates exploit vulnerabilities in internet-exposed applications and services to gain unauthenticated initial access without requiring victim interaction. Targeted platforms include VPN appliances, web application frameworks, and enterprise software with known unpatched CVEs. Exploitation provides a shell or reverse beacon on the externally exposed system, which serves as a staging platform for internal reconnaissance, credential dumping, and lateral movement prior to ransomware deployment. RansomHub's exploitation capability reflects its recruitment of experienced affiliates with access to both public and private exploit tooling, enabling the group to target organizations that have hardened against phishing but maintain unpatched external attack surfaces."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "55968347-c3f0-43fc-813e-7400660e22dd", "30": "fc0f383b-56e2-46f2-9149-53e8c2597bbd", "60": "2a6f3c0a-6820-42d2-aae4-14f97c715f0d", "90": "031a7d9c-e386-41b6-82f2-eb7a8ace70b7", "120": "bddcc144-14df-4557-809f-fef4a3bbe6c6", "150": "30b3235e-9a33-46cc-812b-0b939a5e57f5", "180": "ab053e26-6653-4118-bab4-2de65f7472e5", "210": "98419071-d366-44af-a64d-c808f14672ca", "240": "71a7b719-9df5-4fbf-a48a-ed454f7c2b21", "270": "a05c107c-6a44-499d-9ae7-81cfbde2fb4a", "300": "3241a319-9e50-4248-bfab-ec2021cf5f36", "330": "79cfca66-36e2-4767-9c1d-94973410a92c"}}, {"id": "horizontal_anchor", "instance": "55968347-c3f0-43fc-813e-7400660e22dd", "latches": []}, {"id": "vertical_anchor", "instance": "fc0f383b-56e2-46f2-9149-53e8c2597bbd", "latches": []}, {"id": "vertical_anchor", "instance": "2a6f3c0a-6820-42d2-aae4-14f97c715f0d", "latches": []}, {"id": "vertical_anchor", "instance": "031a7d9c-e386-41b6-82f2-eb7a8ace70b7", "latches": ["8e85c9e3-31ac-44bf-bf2e-2ed81f99a146"]}, {"id": "vertical_anchor", "instance": "bddcc144-14df-4557-809f-fef4a3bbe6c6", "latches": []}, {"id": "vertical_anchor", "instance": "30b3235e-9a33-46cc-812b-0b939a5e57f5", "latches": []}, {"id": "horizontal_anchor", "instance": "ab053e26-6653-4118-bab4-2de65f7472e5", "latches": []}, {"id": "vertical_anchor", "instance": "98419071-d366-44af-a64d-c808f14672ca", "latches": []}, {"id": "vertical_anchor", "instance": "71a7b719-9df5-4fbf-a48a-ed454f7c2b21", "latches": []}, {"id": "vertical_anchor", "instance": "a05c107c-6a44-499d-9ae7-81cfbde2fb4a", "latches": []}, {"id": "vertical_anchor", "instance": "3241a319-9e50-4248-bfab-ec2021cf5f36", "latches": []}, {"id": "vertical_anchor", "instance": "79cfca66-36e2-4767-9c1d-94973410a92c", "latches": []}, {"id": "action", "instance": "fcca1598-bb70-4a88-ae1f-b08a27a92362", "properties": [["name", "Drive-by Compromise"], ["ttp", [["tactic", "TA0001"], ["technique", "T1189"]]], ["description", "RansomHub affiliates use drive-by compromise to deliver malware to victims who visit attacker-controlled or compromised legitimate websites, without requiring any explicit file interaction beyond browsing. Malicious JavaScript or exploit kit frameworks silently profile the visitor's browser environment and deliver an appropriate exploit or social engineering lure \u2014 commonly a fake browser update prompt or CAPTCHA-triggered clipboard injection \u2014 that executes a loader or dropper on the victim host. Drive-by compromise broadens RansomHub's initial access surface beyond targeted email delivery, enabling passive credential or access harvesting from victims in targeted industry verticals who visit industry-relevant watering hole sites seeded by the group."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "1692c1fe-29e0-45c9-8c66-5c0273c9c30e", "30": "93de18b0-5d13-41ea-9691-954851f48e4b", "60": "629c5e6e-a4df-469c-96e3-c8db1dd8993f", "90": "be802ed7-22da-4401-aef0-590b65f80c78", "120": "8e983abb-e38c-47ac-8dc8-03a309b20416", "150": "9838dfdd-fecb-4007-b50e-92c4da641fe4", "180": "07364254-09ae-4b46-b940-4bd4c7ecf564", "210": "26f1cd2c-7197-437f-b99c-9fd05a282398", "240": "8153fcc5-45ad-4619-80a0-9d095b5ee497", "270": "83b42ae7-d0f5-456c-898d-d52854deb134", "300": "8c1162b7-7389-4004-830d-fc53df746063", "330": "0b5a2632-becd-4ff8-a28e-368ce0ca9caa"}}, {"id": "horizontal_anchor", "instance": "1692c1fe-29e0-45c9-8c66-5c0273c9c30e", "latches": []}, {"id": "vertical_anchor", "instance": "93de18b0-5d13-41ea-9691-954851f48e4b", "latches": []}, {"id": "vertical_anchor", "instance": "629c5e6e-a4df-469c-96e3-c8db1dd8993f", "latches": []}, {"id": "vertical_anchor", "instance": "be802ed7-22da-4401-aef0-590b65f80c78", "latches": ["34dad138-140a-4e3f-bcba-f1c7b7520018"]}, {"id": "vertical_anchor", "instance": "8e983abb-e38c-47ac-8dc8-03a309b20416", "latches": []}, {"id": "vertical_anchor", "instance": "9838dfdd-fecb-4007-b50e-92c4da641fe4", "latches": []}, {"id": "horizontal_anchor", "instance": "07364254-09ae-4b46-b940-4bd4c7ecf564", "latches": []}, {"id": "vertical_anchor", "instance": "26f1cd2c-7197-437f-b99c-9fd05a282398", "latches": []}, {"id": "vertical_anchor", "instance": "8153fcc5-45ad-4619-80a0-9d095b5ee497", "latches": []}, {"id": "vertical_anchor", "instance": "83b42ae7-d0f5-456c-898d-d52854deb134", "latches": []}, {"id": "vertical_anchor", "instance": "8c1162b7-7389-4004-830d-fc53df746063", "latches": []}, {"id": "vertical_anchor", "instance": "0b5a2632-becd-4ff8-a28e-368ce0ca9caa", "latches": []}, {"id": "action", "instance": "90f5a7f5-5429-4bca-abba-a6576c078a26", "properties": [["name", "External Remote Services"], ["ttp", [["tactic", "TA0001"], ["technique", "T1133"]]], ["description", "External Remote Services is the central convergence point for all RansomHub initial access vectors, observed in both initial access and persistence tactics (Reports count: 2 each). Following credential theft via phishing or brute force, exploitation of public-facing applications, or drive-by compromise, RansomHub affiliates authenticate to internet-exposed remote access services \u2014 including VPN gateways (Citrix, Fortinet, Pulse Secure), RDP endpoints, and remote management platforms (AnyDesk, ConnectWise) \u2014 to establish a persistent, authenticated tunnel into the internal network. These services serve as the primary pivot point into internal network segments, enabling hands-on-keyboard operations including privilege escalation (T1484.001, T1068), security tool disabling (T1562.001, Reports count: 4), and lateral movement via RDP (T1021.001, Reports count: 3) and SMB (T1021.002) ahead of ransomware detonation and system service termination (T1489)."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "1e8886e0-23d2-47d5-b34c-9880da148e67", "30": "cdf27e24-9438-4cdf-8c87-8810d7793907", "60": "40421c8f-47b5-40bc-9e92-2cf23baa12cf", "90": "f04f221a-0b0b-4d61-b9f8-ca