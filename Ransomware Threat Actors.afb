                            "TA0001"
                        ],
                        [
                            "technique",
                            "T1566.002"
                        ]
                    ]
                ],
                [
                    "description",
                    "Akira operators may leverage targeted spearphishing emails containing malicious links to gain initial access to victim environments. These emails are often designed to appear as legitimate business communications and entice recipients to click embedded URLs leading to credential harvesting pages, malware downloads, or attacker-controlled websites. Successful interaction with these links can result in credential compromise or malware execution."
                ],
                [
                    "confidence",
                    null
                ],
