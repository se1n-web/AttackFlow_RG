ance": "c11fbfee-1fcd-4476-9b29-d4f567106691"}, {"id": "action", "instance": "63b90869-ba75-401a-bbce-c42599c59673", "properties": [["name", "Valid Accounts"], ["ttp", [["tactic", "TA0001"], ["technique", "T1078"]]], ["description", "INC ransomware affiliates rely heavily on valid credentials, including domain and local accounts, to gain and maintain access to victim systems and services. Credentials are obtained through purchase, prior compromise, or credential theft, then reused to authenticate to exposed services and remote access platforms, allowing the group to blend in with normal activity and operate with reduced risk of detection."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "48154b2b-59b5-4e36-8cc6-1e54b1d4e1a0", "30": "cde7bca8-8dea-493e-ae7e-cd98be19e486", "60": "0fff3bba-c238-4dfd-84ae-8bae5994f842", "90": "d7560857-735d-4dd2-937b-2dd6cec939bf", "120": "417179ec-159a-4c17-a746-99320d424842", "150": "7206f619-b4ef-4f92-91f7-ea7ca510ebd3", "180": "a0660fbc-4628-43c6-ad7f-6273d1e0e376", "210": "09b376eb-6e98-42ec-b6ed-e422a48cec11", "240": "aa96255b-d41f-45f1-93e5-737196394b55", "270": "868745cf-9fa0-4e41-8e49-e504be735f67", "300": "7ad2f9a8-c049-4a20-8517-c54648f94401", "330": "1844b4c4-c5d2-49b2-8257-1de04764632b"}}, {"id": "horizontal_anchor", "instance": "48154b2b-59b5-4e36-8cc6-1e54b1d4e1a0", "latches": []}, {"id": "horizontal_anchor", "instance": "cde7bca8-8dea-493e-ae7e-cd98be19e486", "latches": []}, {"id": "vertical_anchor", "instance": "0fff3bba-c238-4dfd-84ae-8bae5994f842", "latches": []}, {"id": "vertical_anchor", "instance": "d7560857-735d-4dd2-937b-2dd6cec939bf", "latches": []}, {"id": "vertical_anchor", "instance": "417179ec-159a-4c17-a746-99320d424842", "latches": []}, {"id": "horizontal_anchor", "instance": "7206f619-b4ef-4f92-91f7-ea7ca510ebd3", "latches": []}, {"id": "horizontal_anchor", "instance": "a0660fbc-4628-43c6-ad7f-6273d1e0e376", "latches": []}, {"id": "horizontal_anchor", "instanc