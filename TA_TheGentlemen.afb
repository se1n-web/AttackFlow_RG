27a9-4724-aa37-f8889a19e4b9", "properties": [["name", "Exploit Public-Facing Application"], ["ttp", [["tactic", "TA0001"], ["technique", "T1190"]]], ["description", "The Gentlemen exploit vulnerabilities in internet-facing applications and services to gain initial access to target environments. This is their primary documented entry vector; successful exploitation provides a foothold on externally exposed systems and a path to pivot into internal networks ahead of credential theft, lateral movement, and ransomware deployment."], ["confidence", null], ["execution_start", null], ["execution_end", null]], "anchors": {"0": "cb077542-d6f0-4d27-8ef0-5af150854848", "30": "e2a64e8d-f881-4573-9e81-6d17052d70e9", "60": "b1498cbc-cb4a-433d-b04e-a6598496b8f4", "90": "1ccff631-459c-4eb5-b4d3-e2c3c31320e9", "120": "9d16cfce-11ab-47bd-82b3-8c3ccab0185c", "150": "cb92fae9-a030-48aa-aa38-8e1b541e3782", "180": "7f2b72b3-fa0e-4b0e-a772-e93a9073a06f", "210": "ee030e89-8fb0-467d-9cd7-4694dc65d7af", "240": "40d2aa8b-2806-4b39-b2e7-7c2c666d819f", "270": "67865da4-f730-4f25-8154-a89965ddccc2", "300": "f5cdd55a-c1e5-48d9-b8c2-e3c01d0f10b2", "330": "7336012d-a21a-49fa-8c66-8107d33c6b99"}}, {"id": "horizontal_anchor", "instance": "77c4d7e8-6845-43ff-9643-7c9d50a0e613", "latches": []}, {"id": "horizontal_anchor", "instance": "de7ff005-5d01-4894-adb6-8cd5c9648ec6", "latches": ["b88959b3-b4ce-4417-9797-9009e6e382c8"]}, {"id": "vertical_anchor", "instance": "1606db91-ee24-4e3c-aae9-4ad40ec2c55e", "latches": ["ede1441c-dbc0-47ef-a9e6-513ed98de29a"]}, {"id": "vertical_anchor", "instance": "f643eb4b-56bf-4a9c-a353-90936f4c402a", "latches": ["988c9bae-0323-4bcf-9b17-c7d91c2e381c"]}, {"id": "vertical_anchor", "instance": "287e7aaf-8326-4a2f-a8d2-9fe3ba8e618a", "latches": ["c913c77c-d5a7-4ff2-baa3-2c9ecba6f85e"]}, {"id": "horizontal_anchor", "instance": "5ceabe4c-265a-40ff-b83f-a204b6726524", "latches": ["7ebe3ba0-eae8-40eb-81f7-093272a91a39"]}, {"id": "horizontal_anchor", "instance": "512c6a8d-5013-4a